{
  "dry_run": false,
  "log_level": "info",
  "interval": 30000000000,

  "safety": {
    "enabled": true,
    "fail_closed": true,
    "require_approval": true,
    "interactive_confirm": true,
    "allow_destructive_actions": true,
    "blocked_namespaces": ["kube-system", "kube-public"],
    "blocked_name_patterns": ["^kube-.*", "^istio-.*", "^linkerd-.*"],
    "max_targets_per_run": 20,
    "max_destructive_actions_per_run": 8
  },

  "stress": {
    "enabled": true,
    "actions": ["cpu", "memory"],
    "duration": 30000000000,
    "cpu_cores": 2,
    "memory_mb": 512,
    "disk_io_workers": 4,
    "temp_dir": "/tmp/yacmo",
    "disk_fill_mb": 1024
  },

  "scheduler": {
    "mode": "continuous",
    "cron_expression": "",
    "max_experiments": 0
  },

  "metrics": {
    "enabled": true,
    "address": ":9090"
  },

  "report": {
    "enabled": true,
    "output_dir": "./reports"
  },

  "notify": {
    "enabled": false,
    "webhooks": [
      {
        "name": "slack-alerts",
        "type": "slack",
        "url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK",
        "headers": {}
      },
      {
        "name": "discord-alerts",
        "type": "discord",
        "url": "https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK",
        "headers": {}
      },
      {
        "name": "custom-webhook",
        "type": "generic",
        "url": "https://your-service.example.com/chaos-events",
        "headers": {
          "X-API-Key": "your-api-key"
        }
      }
    ]
  }
}
