{
  "dry_run": false,
  "log_level": "info",
  "interval": 30000000000,

  "stress": {
    "enabled": true,
    "actions": ["cpu", "memory"],
    "duration": 30000000000,
    "cpu_cores": 2,
    "memory_mb": 512,
    "disk_io_workers": 4,
    "temp_dir": "/tmp/yacmo",
    "disk_fill_mb": 1024
  },

  "scheduler": {
    "mode": "once",
    "cron_expression": "",
    "max_experiments": 0
  },

  "metrics": {
    "enabled": true,
    "address": ":9090"
  },

  "report": {
    "enabled": true,
    "output_dir": "./reports"
  }

}

