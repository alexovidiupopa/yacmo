{
  "dry_run": false,
  "log_level": "info",
  "interval": 30000000000,

  "network": {
    "enabled": true,
    "interface": "eth0",
    "actions": ["latency", "dns_failure", "bandwidth_limit","corrupt"],
    "latency_ms": 200,
    "jitter_ms": 50,
    "duration": 20000000000,
    "corrupt_percent": 10,
    "bandwidth_limit_kbps": 128
  },

  "scheduler": {
    "mode": "continuous",
    "cron_expression": "",
    "max_experiments": 10
  },

  "metrics": {
    "enabled": true,
    "address": ":9090"
  },

  "report": {
    "enabled": true,
    "output_dir": "./reports"
  }

}

